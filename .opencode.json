{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-storyclaw", "opencode-novel-plugin", "opencode-ai-novel-factory"],
  "instructions": [".opencode/instructions/novel-agent.md"],
  "agent": {
    "novel-writer": {
      "description": "小说续写助手 — 自动加载大纲、规则、人物，按规则续写",
      "mode": "subagent",
      "prompt": "{file:.opencode/instructions/novel-agent.md}",
      "permission": {
        "bash": "allow",
        "read": "allow",
        "write": "allow",
        "edit": "allow"
      }
    }
  }
}
